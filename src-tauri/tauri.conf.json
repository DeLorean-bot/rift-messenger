{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RIFT",
  "version": "0.5.1",
  "identifier": "io.rift.messenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RIFT — связь без центра",
        "width": 1280,
        "height": 800,
        "minWidth": 820,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["rift"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaW5pIHB1YmxpYyBrZXk6IEM5QjJGRUY5M0Y5M0UxNgpSV1FXUHZtVDd5K2JERWRjK3V3aGoydmJ1SlJjcHBmVHRENmVkTmxZZ3dwQkdsaTlXaFRnNDEveQo=",
      "endpoints": ["https://github.com/DeLorean-bot/rift-messenger/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "category": "SocialNetworking",
    "shortDescription": "Прямой P2P-мессенджер без центрального сервера",
    "longDescription": "RIFT соединяет устройства напрямую для чата, звонков, демонстрации экрана и передачи файлов."
  }
}
